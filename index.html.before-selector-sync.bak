            <section class="student-app-panel" data-student-app-panel="biblioteca" hidden>
              <div class="student-panel-head">
                <h4>Biblioteca de exercícios</h4>
                <p>Busque por nome ou grupo muscular</p>
              </div>
              <div class="student-library-tools">
                <label class="student-library-search-wrap">
                  <input type="search" placeholder="Buscar exercício..." data-student-library-search />
                </label>
              </div>
              <div class="student-library-manage" data-library-manager hidden>
                <button class="student-group-create-btn student-group-create-btn-top" type="button" data-library-manager-toggle>
                  <span>Adicionar à biblioteca</span>
                </button>
                <p class="student-form-error student-library-manage-feedback" data-library-manager-feedback aria-live="polite"></p>
                <article class="admin-overview-table-card student-library-manage-card" data-library-manager-form-wrap hidden>
                  <header class="trainer-library-head">
                    <div class="trainer-library-head-main">
                      <div>
                        <h5>Biblioteca de Exercícios</h5>
                        <p>Adicione um novo exercício à sua biblioteca.</p>
                      </div>
                    </div>
                    <button class="trainer-library-close-btn" type="button" data-library-manager-close aria-label="Fechar cadastro">
                      <span aria-hidden="true">&times;</span>
                    </button>
                  </header>
                  <form class="trainer-library-form trainer-library-form--model" data-trainer-library-form novalidate>
                    <div class="trainer-workout-form-grid trainer-library-grid">
                      <label>
                        <span>Nome do exercício <em class="trainer-required-chip">Obrigatório</em></span>
                        <input type="text" name="name" placeholder="Ex: Supino reto" data-trainer-library-name required />
                      </label>
                      <label>
                        <span>Grupo muscular <em class="trainer-required-chip">Obrigatório</em></span>
                        <select name="group" data-trainer-library-group>
                          <option value="peito">Peito</option>
                          <option value="costas">Costas</option>
                          <option value="ombros">Ombros</option>
                          <option value="biceps">Bíceps</option>
                          <option value="triceps">Tríceps</option>
                          <option value="antebraco">Antebraço</option>
                          <option value="abdomen">Abdômen</option>
                          <option value="lombar">Lombar</option>
                          <option value="gluteos">Glúteos</option>
                          <option value="quadriceps">Quadríceps</option>
                          <option value="posterior">Posterior de coxa</option>
                          <option value="adutores">Adutores</option>
                          <option value="abdutores">Abdutores</option>
                          <option value="panturrilhas">Panturrilhas</option>
                        </select>
                      </label>
                      <label class="trainer-field-full">
                        <span>Descrição / execução técnica</span>
                        <textarea name="description" placeholder="Execução técnica do exercício" data-trainer-library-description required></textarea>
                      </label>

                      <hr class="trainer-form-divider trainer-field-full" />

                      <div class="trainer-library-defaults trainer-field-full">
                        <h6>Valores padrão (opcional)</h6>
                      </div>
                      <div class="trainer-metrics-row trainer-field-full trainer-library-metrics">
                        <label class="trainer-metric-field">
                          <span>Repetições</span>
                          <input type="number" name="repetitions" min="1" step="1" value="10" data-trainer-library-repetitions required />
                        </label>
                        <label class="trainer-metric-field">
                          <span>Tempo</span>
                          <input type="number" name="durationSeconds" min="10" step="1" value="60" data-trainer-library-duration required />
                        </label>
                        <label class="trainer-metric-field">
                          <span>Descanso</span>
                          <input type="number" name="restSeconds" min="0" step="1" value="30" data-trainer-library-rest required />
                        </label>
                      </div>

                      <hr class="trainer-form-divider trainer-field-full" />

                      <div class="trainer-library-media-grid trainer-field-full">
                        <label class="trainer-library-media-drop">
                          <span class="trainer-library-media-title">Imagens (opcional)</span>
                          <span class="trainer-library-media-zone">
                            <input type="file" name="imageFile" accept="image/*" capture="environment" data-trainer-library-image-file />
                            <span class="trainer-library-media-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24">
                                <path d="M12 16V5m0 0-4 4m4-4 4 4M4 15v4h16v-4"/>
                              </svg>
                            </span>
                            <strong>Arraste imagens ou clique para selecionar</strong>
                          </span>
                        </label>

                        <label class="trainer-library-media-drop">
                          <span class="trainer-library-media-title">Vídeos (opcional)</span>
                          <span class="trainer-library-media-zone">
                            <input type="file" name="videoFile" accept="video/*" data-trainer-library-video-file />
                            <span class="trainer-library-media-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24">
                                <path d="M12 16V5m0 0-4 4m4-4 4 4M4 15v4h16v-4"/>
                              </svg>
                            </span>
                            <strong>Arraste vídeos ou clique para selecionar</strong>
                          </span>
                        </label>
                      </div>
                    </div>
                    <div class="trainer-library-actions">
                      <button class="trainer-library-cancel-btn" type="button" data-library-manager-cancel>Cancelar</button>
                      <button class="student-login-btn trainer-workout-submit trainer-library-submit-btn" type="submit" data-trainer-library-submit>
                        <span>Adicionar à biblioteca</span>
                      </button>
                    </div>
                  </form>
                </article>
              </div>
              <div class="student-library-grid" data-student-library-grid></div>

              <section class="student-group-guide-sheet" data-group-guide-sheet hidden>
                <header class="student-group-guide-top">
                  <button class="student-group-guide-back student-group-guide-back-arrow" type="button" data-group-guide-back aria-label="Voltar">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                  </button>
                  <h5 data-group-guide-title>Exercícios</h5>
