              </section>

              <section class="student-group-detail-sheet" data-group-detail-sheet hidden>
                <header class="student-group-guide-top">
                  <button class="student-group-guide-back student-group-guide-back-arrow" type="button" data-group-detail-back aria-label="Voltar">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                  </button>
                  <h5 data-group-detail-title>Exercício</h5>
                </header>
                <p class="student-group-detail-muscle" data-group-detail-muscle>Músculo primário</p>
                <div class="student-group-detail-media">
