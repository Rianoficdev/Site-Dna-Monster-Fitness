<!doctype html>
<html lang="pt-BR">
<head>
  <!-- Metadados basicos de SEO e responsividade -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DNA Monster Fitness | Academia Premium</title>
  <meta name="description" content="Academia premium com musculação, funcional, cardio e acompanhamento personalizado. Resultados reais com estrutura moderna." />
  <meta name="keywords" content="academia, musculação, treino funcional, cardio, personal trainer, fitness" />
  <meta name="theme-color" content="#1CBF5C" />
  <meta name="dna-api-base-url" content="" />
  <meta property="og:title" content="DNA Monster Fitness" />
  <meta property="og:description" content="A melhor experiência fitness com estrutura premium e resultados reais." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css?v=20260225-014" />
</head>
<body>
  <!-- Header fixo com navegacao principal e atalhos -->
  <header class="site-header">
    <div class="container nav">
      <!-- Logo principal (varia entre modo claro e escuro) -->
      <a class="logo" href="#home" aria-label="DNA Monster Fitness">
        <img class="logo-image logo-image-light" src="aba de img/nova logo.png" alt="DNA Monster Fitness" />
        <img class="logo-image logo-image-dark" src="aba de img/logo branca.png" alt="" aria-hidden="true" />
      </a>
      <!-- Menu principal (desktop / mobile) -->
      <nav class="menu" aria-label="Navegação principal">
        <a href="#home">Início</a>
        <a href="#modalidades">Modalidades</a>
        <a href="#planos">Planos</a>
        <a href="#localizacao">Localização</a>
        <a href="#contato">Contato</a>
      </nav>
      <div class="header-actions">
        <!-- Aciona fluxo SPA da Area do Aluno -->
        <a class="btn btn-primary header-student-btn" href="#" data-student-open>Área do Aluno</a>
        <!-- Botao de alternancia de tema -->
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="Ativar modo noturno"
          aria-pressed="false"
          title="Ativar modo noturno"
        >
          <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 14.5A8.5 8.5 0 1 1 9.5 4 7 7 0 0 0 20 14.5z"></path>
          </svg>
          <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="4.2"></circle>
            <path d="M12 2.8v2.4M12 18.8v2.4M21.2 12h-2.4M5.2 12H2.8M18.5 5.5l-1.8 1.8M7.3 16.7l-1.8 1.8M18.5 18.5l-1.8-1.8M7.3 7.3 5.5 5.5"></path>
          </svg>
        </button>
      </div>
      <!-- Botao hamburguer para menu mobile -->
      <button class="menu-toggle" aria-label="Abrir menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    <!-- Hero principal -->
    <section id="home" class="hero">
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        <div class="hero-text reveal">
          <img class="hero-logo-mobile" src="aba de img/logo branca.png" alt="DNA Monster Fitness" />
          <h1><span class="hero-firstline">A MELHOR</span> <br /><span class="nowrap">EXPERIÊNCIA FITNESS</span></h1>
          <p>
            <span class="desktop-only">Treinos completos, estrutura moderna e acompanhamento para resultados reais. Tudo em um ambiente limpo, <span class="nowrap">organizado e motivador</span>.</span>
            <span class="mobile-only">Treinos completos, estrutura moderna e acompanhamento para resultados reais.</span>
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="#contato">Matricule-se agora</a>
            <a class="btn btn-outline" href="#planos">Ver planos</a>
          </div>
          <div class="hero-highlight">
            <div>
              <strong>+1.500</strong>
              <span>alunos satisfeitos</span>
            </div>
            <div>
              <strong>+60</strong>
              <span>equipamentos premium</span>
            </div>
            <div>
              <strong>10 anos</strong>
              <span>de resultados</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Secao de horarios e status dinamico (aberta/fechada) -->
    <section id="horario" class="section schedule-section">
      <div class="container">
        <div class="schedule-header reveal">
          <h2>Horário de Funcionamento</h2>
        </div>
        <div class="schedule-grid">
          <article class="schedule-card reveal">
            <p class="schedule-day">Segunda à Sexta</p>
            <p class="schedule-time">5:30 às 22:00</p>
          </article>
          <article class="schedule-card reveal">
            <p class="schedule-day">Sábados</p>
            <p class="schedule-time">6:00 às 17:00</p>
          </article>
          <article class="schedule-card reveal">
            <p class="schedule-day">Domingos</p>
            <p class="schedule-time">6:00 às 11:00</p>
          </article>
        </div>
        <div class="schedule-status-wrap">
          <span class="status-chip" data-gym-status aria-live="polite">
            <span class="status-dot" aria-hidden="true"></span>
            <span class="status-text">Verificando status...</span>
          </span>
        </div>
      </div>
    </section>

    <!-- Secao de modalidades -->
    <section id="modalidades" class="section alt">
      <div class="container">
        <div class="section-header reveal">
          <h2>Modalidades e Aulas</h2>
          <p>Programas completos para força, resistência e performance.</p>
        </div>
        <div class="grid-4">
          <article class="card reveal">
            <div class="card-image image-1"></div>
            <h3>Musculação</h3>
            <p>Foco em hipertrofia<br />força e definição.</p>
          </article>
          <article class="card reveal">
            <div class="card-image image-2"></div>
            <h3>Treino funcional</h3>
            <p>Movimentos dinâmicos para performance real.</p>
          </article>
          <article class="card reveal">
            <div class="card-image image-3"></div>
            <h3>Cardio</h3>
            <p>Condicionamento e resistência com tecnologia.</p>
          </article>
          <article class="card reveal">
            <div class="card-image image-4"></div>
            <h3>Personalizado</h3>
            <p>Planos feitos sob medida com acompanhamento.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Secao avaliacao + personal -->
    <section id="avaliacao" class="section">
      <div class="container split">
        <div class="reveal">
          <h2 class="avaliacao-title">
            <img class="avaliacao-title-image avaliacao-title-image-light" src="aba de img/texto.png" alt="Avaliação Física e Treino Personalizado" />
            <img class="avaliacao-title-image avaliacao-title-image-dark" src="aba de img/texto branco.png" alt="" aria-hidden="true" />
          </h2>
          <p>Comece com avaliação completa e receba um plano de treino ajustado ao seu objetivo, seja ganho de massa, emagrecimento ou performance.</p>
          <div class="check-list">
            <span>Plano individual</span>
            <span>Acompanhamento técnico</span>
            <span>Evolução monitorada</span>
          </div>
        </div>
        <div class="trainer-card reveal">
          <div class="trainer-photo"></div>
          <h3>Personal Trainer</h3>
          <p>Profissionais dedicados para acelerar seus resultados.</p>
          <a class="btn btn-primary" href="#contato">Agendar avaliação</a>
        </div>
      </div>
    </section>

    <!-- Secao de planos -->
    <section id="planos" class="section plans-section">
      <div class="container">
        <div class="section-header plans-header reveal">
          <h2>JÁ CONHECE OS NOSSOS PLANOS?</h2>
          <p>Confira as ofertas que preparamos para sua evolução e escolha o plano ideal para começar hoje.</p>
        </div>
        <div class="plans-stage">
          <div class="plans-grid">
            <article class="plan-card reveal">
              <div class="plan-topbar" aria-hidden="true"></div>
              <h3>Plano Mensal</h3>
              <p class="plan-price"><small>R$</small>80,00</p>
              <ul class="plan-features">
                <li>Acesso total à musculação</li>
                <li>Aulas coletivas selecionadas</li>
                <li>Acompanhamento técnico</li>
                <li>Suporte via app</li>
              </ul>
              <a class="plan-btn" href="#contato">Plano Mensal <span aria-hidden="true">?</span></a>
            </article>
            <article class="plan-card reveal">
              <div class="plan-topbar" aria-hidden="true"></div>
              <h3>Plano Trimestral</h3>
              <p class="plan-price"><small>R$</small>150,00</p>
              <ul class="plan-features">
                <li>Treino personalizado completo</li>
                <li>Suporte via WhatsApp</li>
                <li>Correção de movimentos por vídeo</li>
                <li>Atualizações periódicas de treino</li>
              </ul>
              <a class="plan-btn" href="#contato">Plano Trimestral<span aria-hidden="true">?</span></a>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- Secao de localizacao com mapa oficial -->
    <section id="localizacao" class="section">
      <div class="container location-layout">
        <div class="section-header reveal">
          <h2>Localização</h2>
          <p>A DNA Monster Fitness está em uma região de fácil acesso, próxima aos principais pontos da cidade, <br /> conforto e praticidade para o seu treino.</p>
        </div>
        <div class="map-box reveal">
          <iframe
            title="Mapa DNA Monster Fitness"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d219.96226768230483!2d-38.612841516664055!3d-3.8740441077476118!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x7c75325fd7d197d%3A0x32f3b7968b0bf629!2sAcademia%20DNA%20Monster%20Fitness!5e1!3m2!1spt-BR!2sbr!4v1770682395108!5m2!1spt-BR!2sbr"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Secao da equipe -->
    <section id="time" class="section team-section">
      <div class="container">
        <div class="section-header team-header reveal">
          <h2>CONHEÇA O NOSSO TIME</h2>
          <p>Profissionais qualificados para te acompanhar em cada evolução.</p>
        </div>
        <div class="team-grid">
          <article class="team-card reveal">
            <div class="team-top-weight" aria-hidden="true"></div>
            <div class="team-photo team-1"></div>
            <h3>Ailton</h3>
            <p class="team-role">Educador Físico</p>
            <p class="team-desc">Especialista em hipertrofia e condicionamento, com atendimento individual e foco total na execução correta.</p>
          </article>
          <article class="team-card reveal">
            <div class="team-top-weight" aria-hidden="true"></div>
            <div class="team-photo team-2"></div>
            <h3>Rogerio Filho</h3>
            <p class="team-role">Personal Trainer</p>
            <p class="team-desc">Treinos de força e periodização estratégica para ganho de performance, evolução consistente e segurança.</p>
          </article>
          <article class="team-card reveal">
            <div class="team-top-weight" aria-hidden="true"></div>
            <div class="team-photo team-3"></div>
            <h3>Hanne</h3>
            <p class="team-role">Personal Trainer</p>
            <p class="team-desc">Acompanhamento dinâmico com foco em mobilidade, resistência e melhoria da capacidade física no dia a dia.</p>
          </article>
          <article class="team-card reveal">
            <div class="team-top-weight" aria-hidden="true"></div>
            <div class="team-photo team-4"></div>
            <h3>Jéssica</h3>
            <p class="team-role">Personal Trainer</p>
            <p class="team-desc">Aulas energéticas e acessíveis para todos os níveis, com atenção ao ritmo, motivação e gasto calórico.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Secao de contato -->
    <section id="contato" class="section contact-section">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-lead reveal">
            <span class="contact-kicker">FAÇA SUA MATRÍCULA</span>
            <h2>Construa com a gente <span>mais um futuro de sucesso!</span></h2>
            <p>Preencha o formulário e receba atendimento personalizado para começar sua jornada na <br />DNA Monster Fitness.</p>
            <p class="contact-emphasis">Em breve, nosso time entrará em contato com você.</p>
          </div>

          <form class="contact-form reveal" aria-label="Formulário de contato">
            <label>
              <span>Nome do Responsável</span>
              <input type="text" name="nome" placeholder="Digite seu nome" required />
            </label>

            <div class="contact-row contact-row-2">
              <label>
                <span>E-mail</span>
                <input type="email" name="email" placeholder="Digite um e-mail válido" required />
              </label>
              <label>
                <span>Telefone para Contato</span>
                <input type="tel" name="telefone" placeholder="Digite um número com DDD" required />
              </label>
            </div>

            <label>
              <span>Objetivo de Interesse</span>
              <select name="objetivo" required>
                <option value="">Selecione uma opção</option>
                <option>Hipertrofia</option>
                <option>Emagrecimento</option>
                <option>Condicionamento físico</option>
                <option>Treino personalizado</option>
              </select>
            </label>

            <label class="contact-consent">
              <input type="checkbox" name="consentimento" required />
              <span>Declaro que li e concordo com o uso dos meus dados para contato e apresentação dos serviços da academia.</span>
            </label>

            <button class="btn btn-primary contact-submit" type="submit">Enviar</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <!-- Overlay SPA da Area do Aluno (loading + login) -->
  <section class="student-area" data-student-area hidden aria-hidden="true">
    <!-- Fundo clicavel para fechar -->
    <div class="student-area-scrim" data-student-close></div>

    <div class="student-area-layer">
      <!-- Etapa 1: loading com video -->
      <div class="student-loading-screen is-visible" data-student-loading>
        <video class="student-loading-video" data-student-video autoplay muted playsinline preload="auto">
          <source src="img/carregamento.mp4" type="video/mp4" />
        </video>
        <p class="student-loading-text">Preparando sua Área do Aluno...</p>
      </div>

      <!-- Etapa 2: tela de login -->
      <div class="student-login-screen" data-student-login>
        <button class="student-area-close" type="button" data-student-close aria-label="Fechar Área do Aluno">&times;</button>

        <div class="student-login-card">
          <img class="student-login-logo" src="aba de img/logo branca.png" alt="DNA Monster Fitness" />
          <h2>Área do Aluno</h2>
          <p class="student-login-subtitle">Acesse seus treinos e acompanhe sua evolução</p>
          <!-- Painel de login -->
          <div class="student-auth-panel is-active" data-student-panel="login">
            <form class="student-login-form" data-student-login-form novalidate>
              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm-7 9a7 7 0 0 1 14 0"/></svg>
                </span>
                <input type="text" name="usuario" placeholder="E-mail" autocomplete="username" data-student-user required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M7 11V8a5 5 0 1 1 10 0v3"/><rect x="4" y="11" width="16" height="10" rx="2"/></svg>
                </span>
                <input type="password" name="senha" placeholder="Senha" autocomplete="current-password" data-student-pass required />
              </label>

              <div class="student-login-options">
                <label class="student-remember-option">
                  <input type="checkbox" data-student-remember />
                  <span>Lembrar login neste aparelho</span>
                </label>
                <label class="student-remember-option">
                  <input type="checkbox" data-student-show-pass />
                  <span>Mostrar senha</span>
                </label>
              </div>

              <p class="student-form-error" data-student-form-error aria-live="polite"></p>

              <button class="student-login-btn" type="submit" data-student-submit>
                <span>Entrar</span>
              </button>

              <a class="student-forgot-link" href="#" data-student-forgot>Esqueci minha senha</a>
              <button class="student-form-link" type="button" data-student-go-register>Ainda não sou aluno - Criar cadastro</button>
              <small class="student-login-note">Acesso exclusivo para alunos</small>
            </form>
          </div>

          <!-- Painel de novo cadastro -->
          <div class="student-auth-panel" data-student-panel="register" hidden>
            <form class="student-register-form" data-student-register-form novalidate>
              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm-7 9a7 7 0 0 1 14 0"/></svg>
                </span>
                <input type="text" name="nome" placeholder="Nome completo" autocomplete="name" data-student-register-name required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M4 7h16v10H4z"/><path d="M4 8l8 6 8-6"/></svg>
                </span>
                <input type="email" name="email" placeholder="E-mail" autocomplete="email" data-student-register-email required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M6 4h4l2 5-3 2a14 14 0 0 0 4 4l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 4 6a2 2 0 0 1 2-2z"/></svg>
                </span>
                <input type="tel" name="telefone" placeholder="Telefone com DDD" autocomplete="tel" data-student-register-phone required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M7 11V8a5 5 0 1 1 10 0v3"/><rect x="4" y="11" width="16" height="10" rx="2"/></svg>
                </span>
                <input type="password" name="nova_senha" placeholder="Crie uma senha" autocomplete="new-password" data-student-register-pass required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M7 11V8a5 5 0 1 1 10 0v3"/><rect x="4" y="11" width="16" height="10" rx="2"/></svg>
                </span>
                <input type="password" name="confirmar_senha" placeholder="Confirmar senha" autocomplete="new-password" data-student-register-pass-confirm required />
              </label>

              <p class="student-form-error" data-student-register-error aria-live="polite"></p>

              <button class="student-login-btn" type="submit" data-student-register-submit>
                <span>Cadastrar</span>
              </button>

              <button class="student-form-link" type="button" data-student-go-login>Já tenho cadastro - Entrar</button>
              <small class="student-login-note">Cadastro inicial sujeito à validação da recepção</small>
            </form>
          </div>

          <!-- Painel de recuperação de senha -->
          <div class="student-auth-panel" data-student-panel="forgot" hidden>
            <form class="student-forgot-request-form" data-student-forgot-request-form novalidate>
              <p class="student-form-helper">Digite o e-mail da sua conta para receber o código de recuperação.</p>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M4 7h16v10H4z"/><path d="M4 8l8 6 8-6"/></svg>
                </span>
                <input type="email" name="recovery_email" placeholder="E-mail cadastrado" autocomplete="email" data-student-forgot-email required />
              </label>

              <p class="student-form-error" data-student-forgot-request-error aria-live="polite"></p>

              <button class="student-login-btn" type="submit" data-student-forgot-request-submit>
                <span>Enviar código</span>
              </button>

              <button class="student-form-link" type="button" data-student-go-login>Voltar para login</button>
            </form>

            <form class="student-forgot-reset-form" data-student-forgot-reset-form novalidate hidden>
              <p class="student-form-helper">Digite o código recebido e crie sua nova senha.</p>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M4 7h16v10H4z"/><path d="M4 8l8 6 8-6"/></svg>
                </span>
                <input type="text" name="recovery_token" placeholder="Código de recuperação" autocomplete="one-time-code" data-student-forgot-token required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M7 11V8a5 5 0 1 1 10 0v3"/><rect x="4" y="11" width="16" height="10" rx="2"/></svg>
                </span>
                <input type="password" name="recovery_new_password" placeholder="Nova senha" autocomplete="new-password" data-student-forgot-new-pass required />
              </label>

              <label class="student-field">
                <span class="student-field-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M7 11V8a5 5 0 1 1 10 0v3"/><rect x="4" y="11" width="16" height="10" rx="2"/></svg>
                </span>
                <input type="password" name="recovery_confirm_password" placeholder="Confirmar nova senha" autocomplete="new-password" data-student-forgot-confirm-pass required />
              </label>

              <p class="student-form-error" data-student-forgot-reset-error aria-live="polite"></p>

              <button class="student-login-btn" type="submit" data-student-forgot-reset-submit>
                <span>Redefinir senha</span>
              </button>

              <button class="student-form-link" type="button" data-student-forgot-back-request>Solicitar novo código</button>
              <button class="student-form-link" type="button" data-student-go-login>Voltar para login</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Etapa 3: aplicativo interno da Area do Aluno (tela cheia) -->
      <div class="student-app-screen" data-student-app>
        <div class="student-app-shell">
          <header class="student-app-topbar">
            <div class="student-app-brand">
              <button class="student-app-brand-logo-wrap" type="button" data-student-home-btn aria-label="Ir para início da Área do Aluno">
                <img class="student-app-brand-logo student-app-brand-logo-light" src="aba de img/nova logo.png" alt="DNA Monster Fitness" />
                <img class="student-app-brand-logo student-app-brand-logo-dark" src="aba de img/logo branca.png" alt="" aria-hidden="true" />
              </button>
              <div class="student-app-brand-meta">
