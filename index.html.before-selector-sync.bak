                <p class="student-form-error trainer-workout-error" data-trainer-workout-error aria-live="polite"></p>

                <article class="admin-overview-table-card trainer-workout-create-card">
                  <header class="admin-overview-table-head">
                    <h5>Informações do Treino</h5>
                    <p class="trainer-card-subtitle">Preencha os dados básicos do treino</p>
                  </header>
                  <form class="trainer-workout-form" data-trainer-workout-form novalidate>
                    <div class="trainer-workout-form-grid trainer-workout-form-grid--model">
                      <label class="trainer-student-field">
                        <span>Aluno <small class="trainer-required-chip">Obrigatório</small></span>
                        <div class="trainer-select-search">
                          <span class="trainer-select-search-icon" aria-hidden="true">
