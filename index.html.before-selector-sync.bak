                      <span>Aluno</span>
                      <select data-trainer-progress-student></select>
                    </label>
                    <small data-trainer-progress-range>Semana atual</small>
                  </div>
                </article>

                <article class="admin-overview-table-card trainer-progress-empty-state" data-trainer-progress-empty>
                  <span class="trainer-progress-empty-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3.2"></circle><path d="M5 19a7 7 0 0 1 14 0"></path></svg>
                  </span>
                  <p>Selecione um aluno para ver as informações detalhadas</p>
                </article>

                <article class="admin-overview-table-card" data-trainer-progress-details hidden>
                  <header class="admin-overview-table-head">
                    <h5>Resumo do aluno</h5>
                  </header>
                  <div class="trainer-progress-student-grid">
                    <article>
                      <small>Peso atual</small>
                      <strong data-trainer-progress-weight>Não informado</strong>
                    </article>
                    <article>
                      <small>Altura</small>
                      <strong data-trainer-progress-height>Não informado</strong>
                    </article>
                    <article>
                      <small>Treinos na semana</small>
                      <strong data-trainer-progress-planned>0</strong>
                    </article>
                    <article>
                      <small>Treinos feitos</small>
                      <strong data-trainer-progress-completed>0</strong>
                    </article>
                    <article>
                      <small>Tempo estimado</small>
                      <strong data-trainer-progress-minutes>0 min</strong>
                    </article>
                    <article>
                      <small>Calorias estimadas</small>
                      <strong data-trainer-progress-kcal>0 kcal</strong>
                    </article>
                    <article>
                      <small>Aderência semanal</small>
                      <strong data-trainer-progress-adherence>0%</strong>
                    </article>
